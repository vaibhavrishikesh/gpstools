<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Fetch static map tiles for the photo stamp (US-008); fails gracefully offline. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- osmdroid checks connectivity before fetching map tiles (US-012). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Needed only on API ≤28 to register captures in MediaStore; scoped storage
         on API 29+ requires no storage permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Gpstools">

        <!-- AdMob app id (US-015). This is Google's official TEST app id so no real
             ads serve during development; swap for the production id before release.
             The Mobile Ads SDK requires this meta-data or it throws on init. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511712" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Gpstools">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
